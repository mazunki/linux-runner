#!/bin/sh
OUT=""
COMPILER="@COMPILER@"
CFLAGS="@CFLAGS@"
SFLAGS="@SFLAGS@"  # internal flags
DEBUGFLAGS="@DEBUGFLAGS@"
SOURCES=""

while [ $# -gt 0 ]; do
    case "$1" in
        --compiler) COMPILER="$2"; shift ;;
        --cflags)   CFLAGS="$2";   shift ;;
        --out)      OUT="$2";      shift ;;
        -*)         echo "compile: unknown flag: $1" >&2; exit 1 ;;
        *)          SOURCES="$SOURCES $1" ;;
    esac
    shift
done

[ -z "$OUT" ] && OUT=$(mktemp)
[ -z "$SOURCES" ] && SOURCES="main.c"

# Detect language
LANG="c"
for f in $SOURCES; do
    case "$f" in
        *.cpp|*.cc|*.cxx) LANG="cpp" ;;
        *.zig)            LANG="zig" ;;
    esac
done

# Default compiler
case "$COMPILER" in
    ""|"@COMPILER@")
        case "$LANG" in
            cpp) COMPILER="c++" ;;
            zig) COMPILER="zig build-exe" ;;
            *)   COMPILER="cc" ;;
        esac
        ;;
esac

compile_c_like() {
    set -- $CFLAGS $SFLAGS $DEBUGFLAGS $SOURCES -o "$OUT"
    set -f
    exec $COMPILER "$@"
}

compile_zig() {
    # SFLAGS is still "internal correctness flags"
    set -- $SOURCES $DEBUGFLAGS $SFLAGS -femit-bin="$OUT"
    set -f
    exec $COMPILER "$@"
}

case "$LANG" in
    zig) compile_zig ;;
    *)   compile_c_like ;;
esac
