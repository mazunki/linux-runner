#!/bin/sh
# packs a static binary into a cpio initrd, written to stdout
BINARY=""

while [ $# -gt 0 ]; do
    case "$1" in
        -*)       echo "mkInitrd: unknown flag: $1" >&2; exit 1 ;;
        *)        BINARY="$1" ;;
    esac
    shift
done

[ -z "$BINARY" ] && { echo "usage: mkInitrd <static ELF executable>" >&2; exit 1; }
[ -x "$BINARY" ] || { echo "mkInitrd: not executable: $BINARY" >&2; exit 1; }

BUILD=$(mktemp -d)
TMP=$(mktemp -d)
trap 'rm -rf "$BUILD" "$TMP"' EXIT

mkdir -p "$TMP/bin" "$TMP/sbin" "$TMP/proc" "$TMP/sys"

cp @BUSYBOX@ "$TMP/bin/busybox"
ln -s busybox "$TMP/bin/sh"
ln -s busybox "$TMP/bin/mount"
ln -s /bin/busybox "$TMP/sbin/poweroff"

cp "$BINARY" "$TMP/bin/app"
chmod +x "$TMP/bin/app"

cat > "$TMP/sbin/init" <<'INIT'
#!/bin/sh
mount -t proc none /proc
mount -t sysfs none /sys
/bin/app
poweroff -f
INIT
chmod +x "$TMP/sbin/init"

(cd "$TMP" && find . -print | @CPIO@ -o -H newc 2>/dev/null)
